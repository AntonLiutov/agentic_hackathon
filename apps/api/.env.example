APP_NAME=Agentic Chat API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://agentic:agentic@postgres:5432/agentic_chat
REDIS_URL=redis://redis:6379/0
ATTACHMENTS_DIR=/data/attachments
CORS_ORIGINS=http://localhost:3000
SESSION_SECRET_KEY=dev-only-session-secret-change-me
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=2592000
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM_EMAIL=no-reply@agentic.chat
SMTP_FROM_NAME=Agentic Chat
